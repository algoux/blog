---
import markUrl from '../assets/brand/algoUX.svg?url';
import wordmarkDarkUrl from '../assets/brand/algoUX-text-dark.svg?url';
import wordmarkLightUrl from '../assets/brand/algoUX-text-light.svg?url';
---

<header class="site-header" aria-label="站点页眉">
  <a class="brand-link" href="/" aria-label="algoUX 博客首页">
    <img class="brand-mark" src={markUrl} alt="" width="36" height="24" />
    <span class="brand-wordmark-wrap" aria-hidden="true">
      <img
        class="brand-wordmark brand-wordmark-light"
        src={wordmarkLightUrl}
        alt=""
        width="104"
        height="27"
      />
      <img
        class="brand-wordmark brand-wordmark-dark"
        src={wordmarkDarkUrl}
        alt=""
        width="104"
        height="27"
      />
    </span>
    <svg
      class="brand-divider"
      viewBox="0 0 32 44"
      aria-hidden="true"
      focusable="false"
    >
      <polygon points="22 3 30 3 10 41 2 41" />
    </svg>
    <span class="brand-section">Blog</span>
  </a>

  <nav class="site-nav" aria-label="主导航">
    <button class="icon-text-button search-trigger" type="button" data-search-open>
      <svg viewBox="0 0 24 24" aria-hidden="true">
        <path
          d="m21 21-4.4-4.4M10.8 18.2a7.4 7.4 0 1 1 0-14.8 7.4 7.4 0 0 1 0 14.8Z"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
        />
      </svg>
      <span>搜索</span>
      <kbd>Cmd K</kbd>
    </button>
    <a class="nav-link secondary-nav-link" href="https://algoux.org/">Home</a>
    <a
      class="nav-link secondary-nav-link"
      href="https://github.com/algoux"
      target="_blank"
      rel="noreferrer noopener"
      >GitHub</a
    >
    <button
      class="icon-button theme-toggle"
      type="button"
      data-theme-toggle
      aria-label="主题：跟随系统。点击切换为浅色"
      title="主题：跟随系统"
    >
      <svg class="theme-icon theme-icon-auto" viewBox="0 0 24 24" aria-hidden="true">
        <path
          d="M4 5.8h16v10.4H4V5.8Zm5.5 14.4h5M12 16.2v4"
          fill="none"
          stroke="currentColor"
          stroke-width="1.8"
          stroke-linecap="round"
          stroke-linejoin="round"
        />
        <path
          d="M17.8 8.4a5.6 5.6 0 0 1-5.6 5.6 5.6 5.6 0 0 0 5.6-5.6Z"
          fill="currentColor"
          opacity=".28"
        />
      </svg>
      <svg class="theme-icon theme-icon-sun" viewBox="0 0 24 24" aria-hidden="true">
        <path
          d="M12 4V2m0 20v-2m8-8h2M2 12h2m13.7-5.7 1.4-1.4M4.9 19.1l1.4-1.4m0-11.4L4.9 4.9m14.2 14.2-1.4-1.4M12 16.5a4.5 4.5 0 1 0 0-9 4.5 4.5 0 0 0 0 9Z"
          fill="none"
          stroke="currentColor"
          stroke-width="1.8"
          stroke-linecap="round"
        />
      </svg>
      <svg class="theme-icon theme-icon-moon" viewBox="0 0 24 24" aria-hidden="true">
        <path
          d="M20.4 14.5A8.4 8.4 0 0 1 9.5 3.6 8.7 8.7 0 1 0 20.4 14.5Z"
          fill="none"
          stroke="currentColor"
          stroke-width="1.8"
          stroke-linejoin="round"
        />
      </svg>
    </button>
    <div class="mobile-nav-menu">
      <button
        class="icon-button nav-menu-toggle"
        type="button"
        data-nav-menu-toggle
        aria-label="打开更多导航"
        aria-expanded="false"
        aria-controls="mobile-nav-panel"
      >
        <svg viewBox="0 0 24 24" aria-hidden="true">
          <path
            d="M4 7h16M4 12h16M4 17h16"
            fill="none"
            stroke="currentColor"
            stroke-width="1.9"
            stroke-linecap="round"
          />
        </svg>
      </button>
      <div class="mobile-nav-panel" id="mobile-nav-panel" data-nav-menu-panel hidden>
        <a href="https://algoux.org/">Home</a>
        <a href="https://github.com/algoux" target="_blank" rel="noreferrer noopener">
          GitHub
        </a>
      </div>
    </div>
  </nav>
</header>

<script>
  const themeKey = 'algoux-blog-theme';
  const toggle = document.querySelector('[data-theme-toggle]');
  const menuToggle = document.querySelector('[data-nav-menu-toggle]');
  const menuPanel = document.querySelector('[data-nav-menu-panel]');
  const siteHeader = document.querySelector('.site-header');
  const root = document.documentElement;
  const themeMeta = document.querySelector('meta[name="theme-color"][data-theme-color]');
  const systemDark = window.matchMedia('(prefers-color-scheme: dark)');
  const themeModes = ['auto', 'light', 'dark'] as const;
  type ThemeMode = (typeof themeModes)[number];
  const themeColors = { light: '#eefaff', dark: '#12384f' };
  const themeLabels: Record<ThemeMode, string> = {
    auto: '跟随系统',
    light: '浅色',
    dark: '深色',
  };

  const isThemeMode = (mode: string | undefined): mode is ThemeMode =>
    mode === 'auto' || mode === 'light' || mode === 'dark';

  const getMode = (): ThemeMode =>
    isThemeMode(root.dataset.themeMode)
      ? root.dataset.themeMode
      : isThemeMode(localStorage.getItem(themeKey) ?? undefined)
        ? (localStorage.getItem(themeKey) as ThemeMode)
        : 'auto';

  const getTheme = (mode: ThemeMode) =>
    mode === 'auto' ? (systemDark.matches ? 'dark' : 'light') : mode;

  const updateThemeButton = (mode: ThemeMode) => {
    if (!(toggle instanceof HTMLButtonElement)) return;
    const currentIndex = themeModes.indexOf(mode);
    const nextMode = themeModes[(currentIndex + 1) % themeModes.length];
    toggle.setAttribute(
      'aria-label',
      `主题：${themeLabels[mode]}。点击切换为${themeLabels[nextMode]}`
    );
    toggle.setAttribute('title', `主题：${themeLabels[mode]}`);
  };

  const applyThemeMode = (mode: ThemeMode) => {
    const theme = getTheme(mode);
    root.dataset.themeMode = mode;
    root.dataset.theme = theme;
    root.classList.toggle('dark', theme === 'dark');
    root.classList.toggle('light', theme === 'light');
    if (mode === 'auto') {
      localStorage.removeItem(themeKey);
    } else {
      localStorage.setItem(themeKey, mode);
    }
    themeMeta?.setAttribute('content', themeColors[theme]);
    updateThemeButton(mode);
  };

  toggle?.addEventListener('click', () => {
    const currentMode = getMode();
    const nextMode = themeModes[(themeModes.indexOf(currentMode) + 1) % themeModes.length];
    applyThemeMode(nextMode);
  });

  updateThemeButton(getMode());
  systemDark.addEventListener?.('change', () => {
    if (getMode() === 'auto') applyThemeMode('auto');
  });

  const setMenuOpen = (open: boolean) => {
    if (!(menuToggle instanceof HTMLButtonElement) || !(menuPanel instanceof HTMLElement)) {
      return;
    }

    menuToggle.setAttribute('aria-expanded', String(open));
    menuToggle.setAttribute('aria-label', open ? '关闭更多导航' : '打开更多导航');
    menuPanel.hidden = !open;
  };

  menuToggle?.addEventListener('click', (event) => {
    event.stopPropagation();
    const isOpen = menuToggle.getAttribute('aria-expanded') === 'true';
    setMenuOpen(!isOpen);
  });

  menuPanel?.addEventListener('click', () => setMenuOpen(false));

  document.addEventListener('click', (event) => {
    if (
      menuPanel instanceof HTMLElement &&
      menuToggle instanceof HTMLElement &&
      !menuPanel.hidden &&
      !menuPanel.contains(event.target as Node) &&
      !menuToggle.contains(event.target as Node)
    ) {
      setMenuOpen(false);
    }
  });

  document.addEventListener('keydown', (event) => {
    if (event.key === 'Escape') setMenuOpen(false);
  });

  const updateHeaderSurface = () => {
    if (!(siteHeader instanceof HTMLElement)) return;
    siteHeader.classList.toggle('is-scrolled', window.scrollY > 24);
  };

  updateHeaderSurface();
  window.addEventListener('scroll', updateHeaderSurface, { passive: true });
</script>
