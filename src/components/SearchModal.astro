<div class="search-modal" data-search-modal hidden>
  <div class="search-backdrop" data-search-close></div>
  <section class="search-dialog" role="dialog" aria-modal="true" aria-labelledby="search-title">
    <div class="search-header">
      <div>
        <h2 id="search-title">搜索博客</h2>
        <p>查找各类产品和功能信息。</p>
      </div>
      <button class="icon-button" type="button" data-search-close aria-label="关闭搜索">
        <svg viewBox="0 0 24 24" aria-hidden="true">
          <path
            d="m6 6 12 12M18 6 6 18"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
          />
        </svg>
      </button>
    </div>
    <label class="search-box">
      <span class="sr-only">搜索关键词</span>
      <svg viewBox="0 0 24 24" aria-hidden="true">
        <path
          d="m21 21-4.4-4.4M10.8 18.2a7.4 7.4 0 1 1 0-14.8 7.4 7.4 0 0 1 0 14.8Z"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
        />
      </svg>
      <input data-search-input type="search" placeholder="搜索文章..." autocomplete="off" />
    </label>
    <div class="search-status" data-search-status>输入关键词以搜索已发布文章。</div>
    <div class="search-results" data-search-results></div>
  </section>
</div>

<script>
  type PagefindResultData = {
    url: string;
    excerpt?: string;
    meta?: {
      title?: string;
    };
  };

  type PagefindResult = {
    data: () => Promise<PagefindResultData>;
  };

  type PagefindModule = {
    search: (query: string) => Promise<{ results: PagefindResult[] }>;
  };

  const modal = document.querySelector<HTMLElement>('[data-search-modal]');
  const input = document.querySelector<HTMLInputElement>('[data-search-input]');
  const status = document.querySelector<HTMLElement>('[data-search-status]');
  const results = document.querySelector<HTMLElement>('[data-search-results]');
  const openButtons = document.querySelectorAll('[data-search-open]');
  const closeButtons = document.querySelectorAll('[data-search-close]');
  let pagefindPromise: Promise<PagefindModule | null> | undefined;
  let activeSearchId = 0;

  const openSearch = () => {
    modal?.removeAttribute('hidden');
    document.body.classList.add('search-open');
    setTimeout(() => input?.focus(), 20);
  };

  const closeSearch = () => {
    modal?.setAttribute('hidden', '');
    document.body.classList.remove('search-open');
  };

  const loadPagefind = async (): Promise<PagefindModule | null> => {
    if (!pagefindPromise) {
      const specifier = '/pagefind/pagefind.js';
      pagefindPromise = import(/* @vite-ignore */ specifier)
        .then((module) => module as PagefindModule)
        .catch(() => null);
    }

    return pagefindPromise;
  };

  const setStatus = (message: string) => {
    if (status) status.textContent = message;
  };

  const renderResults = async (query: string) => {
    const searchId = ++activeSearchId;
    const trimmed = query.trim();
    results?.replaceChildren();

    if (!trimmed) {
      setStatus('输入关键词以搜索已发布文章。');
      return;
    }

    setStatus('正在搜索...');
    const pagefind = await loadPagefind();
    if (searchId !== activeSearchId) return;

    if (!pagefind) {
      setStatus('搜索索引会在生产构建后可用。');
      return;
    }

    const search = await pagefind.search(trimmed);
    if (searchId !== activeSearchId) return;

    const resultData = await Promise.all(
      search.results.slice(0, 8).map((result) => result.data())
    );

    if (!resultData.length) {
      setStatus('没有找到匹配的文章。');
      return;
    }

    setStatus(`找到 ${resultData.length} 条结果`);
    resultData.forEach((result) => {
      const link = document.createElement('a');
      link.className = 'search-result';
      link.href = result.url;
      link.innerHTML = `
        <span class="search-result-title">${result.meta?.title || result.url}</span>
        <span class="search-result-excerpt">${result.excerpt || ''}</span>
      `;
      results?.append(link);
    });
  };

  openButtons.forEach((button) => button.addEventListener('click', openSearch));
  closeButtons.forEach((button) => button.addEventListener('click', closeSearch));
  input?.addEventListener('input', () => {
    renderResults(input.value);
  });

  document.addEventListener('keydown', (event) => {
    if ((event.metaKey || event.ctrlKey) && event.key.toLowerCase() === 'k') {
      event.preventDefault();
      openSearch();
      return;
    }

    if (event.key === 'Escape' && !modal?.hasAttribute('hidden')) {
      closeSearch();
    }
  });
</script>
