---
type Props = {
  currentPage: number;
  totalPages: number;
  previousUrl?: string;
  nextUrl?: string;
};

const { currentPage, totalPages, previousUrl, nextUrl } = Astro.props;
---

{
  totalPages > 1 && (
    <nav class="pagination" aria-label="分页">
      {previousUrl ? (
        <a class="pagination-link" href={previousUrl}>上一页</a>
      ) : (
        <span class="pagination-link is-disabled">上一页</span>
      )}
      <span class="pagination-status">第 {currentPage} / {totalPages} 页</span>
      {nextUrl ? (
        <a class="pagination-link" href={nextUrl}>下一页</a>
      ) : (
        <span class="pagination-link is-disabled">下一页</span>
      )}
    </nav>
  )
}
