---
import BaseLayout from '../components/BaseLayout.astro';
---

<BaseLayout title="页面未找到" description="没有找到请求的 algoUX 博客页面。">
  <section class="index-hero">
    <p class="index-kicker">404</p>
    <h1>页面未找到</h1>
    <p>这篇文章可能已经移动，或者当前链接不完整。</p>
  </section>
  <p class="not-found-action"><a class="pagination-link" href="/">返回首页</a></p>
</BaseLayout>
